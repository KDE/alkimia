#, kde-format
msgid "Unable to parse date for '%1'"
msgstr "Невозможно обработать дату для «'%1»"

#: alkonlinequote_p.cpp:583 alkonlinequote_p.cpp:609 alkonlinequote_p.cpp:647
#, kde-format
msgid "Symbol found: '%1'"
msgstr "Найден код: «%1»"

