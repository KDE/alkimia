#, kde-format
msgid "Unable to parse price for '%1'"
msgstr "Невозможно обработать курс для «%1»"

#: alkonlinequote_p.cpp:506
#, kde-format
msgid "Date found: '%1'"
msgstr "Найдена дата: «%1»"

